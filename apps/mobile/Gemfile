source 'https://rubygems.org'

# You may use http://rbenv.org/ or https://rvm.io/ to install and use this version
ruby ">= 3.2"

# CocoaPods toolchain pinned to one minor so local machines and CI resolve
# identically (Gemfile.lock is committed; CI runs `bundle exec pod install`).
gem 'cocoapods', '~> 1.16.2'
gem 'activesupport', '>= 6.1.7.5', '!= 7.1.0'
gem 'xcodeproj', '~> 1.27'
# Required by CocoaPods under Ruby >= 3.4 (no longer bundled default gems).
gem 'nkf'
gem 'tsort'
